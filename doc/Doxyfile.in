PROJECT_NAME           = "@DOXYGEN_PROJECT_NAME@"
INPUT                 = "@DOXYGEN_INPUT_DIR@"
OUTPUT_DIRECTORY      = "@DOXYGEN_OUTPUT_DIR@"

USE_MATHJAX           = YES
RECURSIVE             = YES
GENERATE_LATEX        = NO
GENERATE_HTML         = YES
USE_MDFILE_AS_MAINPAGE = README.md
EXTRACT_ALL           = YES
EXTRACT_PRIVATE       = NO
EXTRACT_STATIC        = NO
HAVE_DOT              = YES
DOT_MULTI_TARGETS     = YES
CALL_GRAPH            = YES
CALLER_GRAPH          = YES
INLINE_SOURCES        = YES
FILE_PATTERNS         = *.hpp *.h
